# Sentinel — credentials template.
#
# Copy this file to `.env.bot` (gitignored) and fill in your values:
#   cp .env.example .env.bot
#
# Then either run setup.ps1 (which reads this on step 9) or source it
# manually: in PowerShell, use `start_bot.ps1` which loads .env.bot
# before launching main.py.

# Bot token from @BotFather. To get one:
#   1. Open Telegram, search @BotFather, send /newbot.
#   2. Follow prompts; copy the token it returns.
SENTINEL_TELEGRAM_TOKEN=PUT_YOUR_BOT_TOKEN_HERE

# Your Telegram numeric user ID. To find it:
#   1. In Telegram, search @userinfobot, send /start.
#   2. Copy the "Id:" number.
# Comma-separate to authorize multiple users:  123456,987654
SENTINEL_TELEGRAM_USER_ID=PUT_YOUR_NUMERIC_USER_ID_HERE
